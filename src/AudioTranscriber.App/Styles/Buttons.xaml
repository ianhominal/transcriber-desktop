<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ===== Botones =====
        Tres familias: Primary (acción principal), Secondary (acción con contorno) y Danger
        (acción destructiva). Más IconButton (compacto) y LinkButton (texto). Todos definen
        hover / pressed / disabled y un anillo de foco de teclado visible (accesibilidad).
    -->

    <!-- Anillo de foco compartido: se agrega como Border extra en cada template, visible solo
         con IsKeyboardFocused (no con click de mouse) para no ensuciar la UI con el foco por
         defecto de WPF (rectángulo punteado) pero mantener navegación por teclado accesible. -->
    <Style x:Key="NoMouseFocusVisual" TargetType="Control">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <!-- ===== Botón primario (acción principal) ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource NoMouseFocusVisual}">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderThickness="2" BorderBrush="Transparent"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentPressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledSurface}"/>
                            <!-- Era `"White"` hardcodeado: 1.70:1 sobre DisabledSurface en tema claro,
                                 y encima rompía la regla que el propio Colors.Light.xaml:6-10 declara
                                 ("nunca colores hardcodeados"). -->
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextOnDisabledSurface}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Botón secundario (acción con texto, contorno) ===== -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource NoMouseFocusVisual}">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceAlt}"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource BorderStrong}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfacePressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <!-- Antes: Opacity 0.45 sobre "b" — compone fondo+borde+texto contra el
                                 backdrop y daba 1.99:1 (ver A.9, DESIGN-REVIEW-2026-07-16.md). Mismo
                                 par ya verificado que usa PrimaryButton (DisabledSurface/
                                 DisabledTextOnDisabledSurface, 4.90:1), sin tocar BorderBrush. -->
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledSurface}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextOnDisabledSurface}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Alias por compatibilidad -->
    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}"/>

    <!-- ===== Botón de peligro (acción destructiva: borrar, cerrar sesión definitiva, etc.) ===== -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource NoMouseFocusVisual}">
        <Setter Property="Background" Value="{DynamicResource DangerSoft}"/>
        <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- El texto sale del token, no de "White": sobre el rojo CLARO del tema
                             oscuro (#F87171) el blanco daba ~2.5:1. Cada tema define su propia
                             tinta (blanca en claro, oscura en oscuro). -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Danger}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextOnDanger}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DangerHover}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextOnDanger}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <!-- Antes: Opacity 0.4 — además de romper contraste, DangerButton
                                 pinta DangerSoft SIEMPRE (no solo en :hover), así que sacar el
                                 Opacity sin más lo hubiese dejado IDÉNTICO a habilitado (ver A.9,
                                 DESIGN-REVIEW-2026-07-16.md, "puede leerse como habilitado"). Mismo
                                 par ya verificado que usa PrimaryButton/SecondaryButton. -->
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledSurface}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextOnDisabledSurface}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Botón de icono (compacto, cuadrado) ===== -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource NoMouseFocusVisual}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentPressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <!-- Antes: Opacity 0.4 — Background normal es Transparent, así que
                                 sacarlo sin más hubiese dejado el ícono a full contraste, IGUAL que
                                 habilitado (ver A.9, DESIGN-REVIEW-2026-07-16.md, "1.82:1 en
                                 IconButton"). IconButton ya cambia de fondo en :hover/:pressed
                                 (AccentSoft), así que un fondo sólido en disabled es coherente con
                                 su propio lenguaje visual, a diferencia de LinkButton (ver abajo). -->
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledSurface}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextOnDisabledSurface}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Variante de IconButton para acciones destructivas (ej. borrar): mismo tamaño/forma,
         hover/pressed en rojo en vez de acento. -->
    <Style x:Key="IconButtonDanger" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DangerSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DangerSoft}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource FocusRing}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <!-- Antes: Opacity 0.4 — mismo motivo que IconButton (ver arriba):
                                 Background normal Transparent, sin fondo sólido el ícono queda a
                                 full contraste en disabled. -->
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource DisabledSurface}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextOnDisabledSurface}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Botón tipo link ===== -->
    <Style x:Key="LinkButton" TargetType="Button" BasedOn="{StaticResource NoMouseFocusVisual}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <TextBlock x:Name="t" Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="t" Property="TextDecorations" Value="Underline"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AccentPressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="t" Property="TextDecorations" Value="Underline"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <!-- Antes: Opacity 0.45 (era el que el hallazgo original omitió, ver
                                 A.9, DESIGN-REVIEW-2026-07-16.md). LinkButton nunca pinta fondo, ni
                                 siquiera en :hover/:pressed — darle uno acá rompería su propio
                                 lenguaje visual de "texto puro". TextMuted en cambio ya está
                                 verificado (Commit 1) contra las 4 superficies reales de la app
                                 (Bg/Surface/SurfaceAlt/AccentSoft), así que sirve sin importar sobre
                                 qué card caiga este botón — mismo mecanismo que ya usa la fila de
                                 arriba (Setter de Foreground sin TargetName, llega a "t" por
                                 TemplateBinding). -->
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
