<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Iconos vectoriales estilo Lucide (viewBox 24x24, trazo 2, puntas redondeadas), la misma
         familia que usa la web del producto (lucide-react). Reemplazan los glifos de texto que se
         resolvian con DOS fuentes distintas: Segoe UI Symbol (monocromo) y Segoe UI Emoji (a
         color), que es lo que se veia inconsistente.

         Regla de color: NINGUN icono trae color propio. El Stroke/Fill se ata por binding al
         Foreground del boton contenedor (ver estilos IconGlyph / IconGlyphFilled), asi heredan el
         color del tema y las transiciones de hover/press que ya define el estilo IconButton, sin
         duplicar colores ni romper el contraste ya validado. -->

    <StreamGeometry x:Key="Icon.Plus">M5 12h14 M12 5v14</StreamGeometry>
    <StreamGeometry x:Key="Icon.Pencil">M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z</StreamGeometry>
    <StreamGeometry x:Key="Icon.Trash">M3 6h18 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M10 11v6 M14 11v6</StreamGeometry>
    <StreamGeometry x:Key="Icon.Refresh">M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8 M21 3v5h-5 M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16 M3 21v-5h5</StreamGeometry>
    <StreamGeometry x:Key="Icon.Search">M11 3a8 8 0 1 0 0 16 8 8 0 0 0 0-16z M21 21l-4.35-4.35</StreamGeometry>
    <StreamGeometry x:Key="Icon.Close">M18 6 6 18 M6 6l12 12</StreamGeometry>
    <StreamGeometry x:Key="Icon.FolderOpen">M6 14l1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.55 6a2 2 0 0 1-1.94 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2</StreamGeometry>
    <StreamGeometry x:Key="Icon.Play">M6 3l14 9-14 9z</StreamGeometry>
    <StreamGeometry x:Key="Icon.Stop">M7 7h10v10H7z</StreamGeometry>

    <!-- Icono de contorno (la mayoria). El trazo sigue el Foreground del boton por binding al
         ancestro Button: cuando IconButton cambia el Foreground en hover/press/tema, el Stroke se
         actualiza solo. ClipToBounds queda en false (default) a proposito: el trazo puede exceder
         apenas el recuadro 18x18 y se dibuja completo dentro del boton de 34x34, sin recortarse. -->
    <Style x:Key="IconGlyph" TargetType="Path">
        <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue=Gray}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>

    <!-- Icono relleno (solo los controles de transporte: reproducir / detener), donde una forma
         solida se lee mejor que un contorno a tamano chico. Mismo criterio de color. -->
    <Style x:Key="IconGlyphFilled" TargetType="Path">
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}, FallbackValue=Gray}"/>
        <Setter Property="Width" Value="15"/>
        <Setter Property="Height" Value="15"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>

</ResourceDictionary>
