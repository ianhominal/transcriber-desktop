<Application x:Class="AudioTranscriber.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AudioTranscriber.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Sistema de diseño centralizado: paleta, tipografía, botones, inputs y
                     controles (Card, ToggleSwitch, TreeView, Expander, Slider, ScrollBar) viven en
                     Styles/ para que TODAS las ventanas compartan la misma familia visual.
                     Cualquier ventana nueva debe consumir estos recursos en vez de hardcodear
                     colores/estilos. Excepción: Spinner ya NO es un Style de acá, es un
                     UserControl (ver Controls/Spinner.xaml) por un bug de NameScope de WPF con
                     Storyboard.TargetName dentro de un ControlTemplate compartido.

                     Colors.Light.xaml acá es solo el valor por default para diseño/primer paint
                     (antes de que corra código): ThemeManager.Apply (llamado en App.OnStartup con
                     el tema guardado en AppSettings.Theme, y de nuevo cuando el usuario lo cambia
                     en Configuración) REEMPLAZA esta entrada por Colors.Dark.xaml si corresponde.
                     Todos los consumidores de estas claves de color usan DynamicResource (no
                     StaticResource) para que ese reemplazo se refleje en vivo sin reiniciar. -->
                <ResourceDictionary Source="Styles/Colors.Light.xaml"/>
                <ResourceDictionary Source="Styles/Typography.xaml"/>
                <ResourceDictionary Source="Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Styles/Icons.xaml"/>
                <ResourceDictionary Source="Styles/Inputs.xaml"/>
                <ResourceDictionary Source="Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Conversores -->
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <local:InverseBooleanConverter x:Key="InverseBoolean"/>
            <local:AvatarUrlToImageConverter x:Key="AvatarUrlToImage"/>
            <local:CountToVisibilityConverter x:Key="CountToVisibility"/>
            <local:ProjectColorToBrushConverter x:Key="ProjectColorToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
