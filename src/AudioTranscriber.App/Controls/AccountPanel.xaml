<UserControl x:Class="AudioTranscriber.App.Controls.AccountPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <!-- Bloque de "Cuenta" (avatar/iniciales + nombre + email + botón Iniciar/Cerrar sesión),
         extraído de SettingsWindow.xaml y SyncWindow.xaml (C.4, DESIGN-REVIEW-2026-07-16.md).
         Alcance del control: SOLO este Grid (columnas */Auto). El SectionLabel "Cuenta" y el
         Border Card que lo envuelven quedan afuera, en cada ventana — Settings usa una Card por
         sección, Sync una sola Card grande con StackPanel interno; ese envoltorio nunca fue parte
         del duplicado real.

         NO tiene DataContext propio: hereda el de la ventana contenedora (SyncCoordinator.Instance,
         seteado en SettingsWindow.xaml.cs / SyncWindow.xaml.cs). Si algún día se le agrega un
         DataContext acá, los 6 bindings de abajo (IsLoggedIn/UserName/UserEmail/UserInitials/
         UserAvatarUrl/LoginCommand/LogoutCommand) se rompen en silencio: WPF no tira excepción,
         el control simplemente deja de mostrar datos.

         Compact (DependencyProperty, ver AccountPanel.xaml.cs) es el único punto real donde
         divergían las dos ventanas: avatar 44px/iniciales 15/gap 12/nombre 14 (Settings, default)
         vs. avatar 40px/iniciales 14/gap 10/nombre 13 (Sync, Compact="True"). Se preservan tal
         cual estaban en cada una — unificar el tamaño es una decisión visual que el reporte marca
         fuera de este alcance (las ventanas nunca se ven juntas). -->

    <UserControl.Resources>
        <Style x:Key="AccountAvatarBox" TargetType="Grid">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Compact, ElementName=Root}" Value="True">
                    <Setter Property="Width" Value="40"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="Margin" Value="0,0,10,0"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Placeholder de iniciales: siempre presente debajo; si el avatar carga bien queda
             tapado por el Ellipse de arriba, y si no hay avatar (o falla la carga: el converter
             devuelve null) se ve directamente. El Ellipse no fija Width/Height propios: el Grid
             padre (AccountAvatarBox) ya fija el tamaño y el Stretch default lo llena igual. -->
        <Style x:Key="AccountAvatarCircle" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoft}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Compact, ElementName=Root}" Value="True">
                    <Setter Property="CornerRadius" Value="20"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccountAvatarInitials" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Compact, ElementName=Root}" Value="True">
                    <Setter Property="FontSize" Value="14"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccountNameText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Compact, ElementName=Root}" Value="True">
                    <Setter Property="FontSize" Value="13"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Sin sesión -->
        <TextBlock Grid.Column="0" Text="No has iniciado sesión." VerticalAlignment="Center"
                   Foreground="{DynamicResource TextSecondary}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Button Grid.Column="1" Content="Iniciar sesión" Command="{Binding LoginCommand}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Con sesión: avatar (foto o iniciales) + nombre + email -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <Grid Style="{StaticResource AccountAvatarBox}">
                <Border Style="{StaticResource AccountAvatarCircle}">
                    <TextBlock Text="{Binding UserInitials}" Style="{StaticResource AccountAvatarInitials}"/>
                </Border>
                <Ellipse>
                    <Ellipse.Fill>
                        <ImageBrush Stretch="UniformToFill"
                                    ImageSource="{Binding UserAvatarUrl, Converter={StaticResource AvatarUrlToImage}}"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding UserName}" Style="{StaticResource AccountNameText}"/>
                <TextBlock Text="{Binding UserEmail}" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
        </StackPanel>
        <Button Grid.Column="1" Content="Cerrar sesión" Command="{Binding LogoutCommand}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</UserControl>
