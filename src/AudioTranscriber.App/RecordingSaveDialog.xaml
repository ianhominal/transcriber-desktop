<Window x:Class="AudioTranscriber.App.RecordingSaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height" Width="420" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Surface}" FontFamily="Segoe UI" FontSize="14"
        Foreground="{DynamicResource TextPrimary}" Title="Guardar grabación">
    <StackPanel Margin="20">
        <TextBlock Text="Proyecto" Foreground="{DynamicResource TextSecondary}" Margin="2,0,0,4"/>
        <ComboBox x:Name="ProjectCombo" Height="32" VerticalContentAlignment="Center"/>

        <TextBlock Text="Título" Foreground="{DynamicResource TextSecondary}" Margin="2,14,0,4"/>
        <TextBox x:Name="TitleBox" Style="{StaticResource InputBox}" Padding="8,7"
                 KeyDown="OnInputKeyDown"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancelar" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Guardar" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
