<Window x:Class="AudioTranscriber.App.BrainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioTranscriber.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Chat con IA — Audio Transcriber" Height="640" Width="560"
        MinHeight="440" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg}" FontFamily="Segoe UI" FontSize="14"
        Foreground="{DynamicResource TextPrimary}">

    <!-- "Chat con IA" en alcance "Todas mis notas" (ver BrainViewModel; nombre de UI unificado
         2026-07-14, ver commit 7f20a43 de la web): preguntarle a la IA sobre TODAS las notas del
         usuario, no una transcripción puntual (para eso está el chat embebido en NoteDetailWindow,
         con el selector de alcance en "Esta nota"). Mismo WindowChrome/TitleBar que el resto de las
         ventanas "Híbrido nativo" (FormatosWindow/NoteDetailWindow). -->

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                             ResizeBorderThickness="6"
                             GlassFrameThickness="0"
                             CornerRadius="0"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:TitleBar x:Name="WindowTitleBar" Grid.Row="0" TitleText="Chat con IA"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Chat con IA" Style="{StaticResource TitleText}"/>
                    <TextBlock Text="Alcance: todas mis notas. Preguntale a la IA: &quot;¿qué dije sobre X?&quot;, &quot;juntá mis ideas sobre Y&quot;."
                               Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Región viva: mismo criterio ARIA "log" que NoteDetailWindow (se ACUMULA una
                     lista de mensajes, no se reemplaza un único resultado). -->
                <Grid Grid.Row="1">
                    <!-- Empty state: sin preguntas todavía. -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsHitTestVisible="False" MaxWidth="320"
                                Visibility="{Binding Messages.Count, Converter={StaticResource CountToVisibility}}">
                        <TextBlock Text="Preguntale algo a la IA sobre todas tus notas" HorizontalAlignment="Center"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="Busca sobre las notas más relevantes para responder."
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"
                                   FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>

                    <ScrollViewer x:Name="MessagesScroll" VerticalScrollBarVisibility="Auto"
                                  AutomationProperties.LiveSetting="Polite">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="10,7" Margin="0,0,0,8" MaxWidth="360">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceAlt}"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Accent}"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- "Guardar como nota" solo en respuestas del asistente. -->
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                        Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibility}}">
                                                <Button Content="{Binding SaveNoteLabel}" Style="{StaticResource LinkButton}"
                                                        FontSize="11" IsEnabled="{Binding CanSaveAsNote}"
                                                        Command="{Binding DataContext.SaveMessageAsNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SaveNoteError}" Foreground="{DynamicResource Danger}"
                                                       TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"
                                                       Visibility="{Binding SaveNoteError, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource Danger}"
                           TextWrapping="Wrap" FontSize="12" Margin="0,10,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}"/>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Style="{StaticResource InputBox}"
                              Text="{Binding Question, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"
                              AutomationProperties.Name="Pregunta para el Chat con IA sobre todas tus notas">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AskCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2" Content="Preguntar" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AskCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <Button Grid.Column="2" Content="Detener" Style="{StaticResource SecondaryButton}"
                            Command="{Binding StopCommand}"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
