<Window x:Class="AudioTranscriber.App.VocabularyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioTranscriber.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Vocabulario — Audio Transcriber" Height="620" Width="480"
        MinHeight="420" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg}" FontFamily="Segoe UI" FontSize="14"
        Foreground="{DynamicResource TextPrimary}">

    <!-- Gestión NATIVA del vocabulario custom (nombres/jerga que el usuario siempre corrige a
         mano), mismo criterio "Híbrido nativo" que NoteDetailWindow: consume /api/vocabulary*
         directo, sin WebView. Ver VocabularyViewModel. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                             ResizeBorderThickness="6"
                             GlassFrameThickness="0"
                             CornerRadius="0"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:TitleBar x:Name="WindowTitleBar" Grid.Row="0" TitleText="Vocabulario"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="Vocabulario" Style="{StaticResource TitleText}"/>
                    <TextBlock Text="Nombres, marcas o jerga que siempre corregís a mano. La transcripción los usa para corregir automáticamente."
                               Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{DynamicResource Danger}"
                           TextWrapping="Wrap" FontSize="12" Margin="0,10,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}"/>

                <!-- Agregar: siempre visible arriba de la lista (acción principal de esta ventana). -->
                <Grid Grid.Row="2" Margin="0,14,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource InputBox}"
                             Text="{Binding NewTermText, UpdateSourceTrigger=PropertyChanged}"
                             Height="34" KeyDown="OnNewTermKeyDown"/>
                    <Button Grid.Column="2" Content="Agregar" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddTermCommand}"/>
                </Grid>

                <!-- Lista de términos -->
                <Grid Grid.Row="3">
                    <controls:Spinner Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Top"
                                       Margin="0,20,0,0"
                                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="Todavía no tenés términos guardados. Agregá el primero arriba."
                               TextWrapping="Wrap" FontSize="12" HorizontalAlignment="Center"
                               Margin="0,20,0,0" Foreground="{DynamicResource TextMuted}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLoading}" Value="False"/>
                                            <Condition Binding="{Binding Terms.Count}" Value="0"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding Terms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceAlt}" CornerRadius="8"
                                            Padding="10,8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Term}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" FontSize="13"/>
                                            <Button Grid.Column="1" Content="Editar" Style="{StaticResource SecondaryButton}"
                                                    Padding="10,5" FontSize="11" Margin="0,0,6,0"
                                                    Command="{Binding DataContext.EditTermCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="2" Content="Borrar" Style="{StaticResource DangerButton}"
                                                    Padding="10,5" FontSize="11"
                                                    Command="{Binding DataContext.DeleteTermCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
