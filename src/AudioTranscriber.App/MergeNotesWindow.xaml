<Window x:Class="AudioTranscriber.App.MergeNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioTranscriber.App.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Unir notas — Audio Transcriber" Height="680" Width="600"
        MinHeight="460" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg}" FontFamily="Segoe UI" FontSize="14"
        Foreground="{DynamicResource TextPrimary}">

    <!-- "Unir notas" NATIVO (ver MergeNotesViewModel): combina varias transcripciones en un solo
         documento generado por IA. Mismo WindowChrome/TitleBar que el resto de las ventanas
         "Híbrido nativo". -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                             ResizeBorderThickness="6"
                             GlassFrameThickness="0"
                             CornerRadius="0"
                             UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:TitleBar x:Name="WindowTitleBar" Grid.Row="0" TitleText="Unir notas"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Unir notas" Style="{StaticResource TitleText}"/>
                        <TextBlock Text="La IA arma un solo documento a partir de las notas elegidas."
                                   Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Lista de notas elegidas (solo lectura, informativa). -->
                    <Border Grid.Row="1" Background="{DynamicResource SurfaceAlt}" CornerRadius="10"
                            Padding="12" Margin="0,14,0,0" MaxHeight="140">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding NoteTitles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat='•  {0}'}" TextWrapping="Wrap"
                                                   FontSize="13" Margin="0,2,0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Instrucción opcional. -->
                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <TextBlock Text="Instrucción (opcional)" Style="{StaticResource SectionLabel}" Margin="2,0,0,4"/>
                        <TextBlock Text="Ej. &quot;Armá una minuta con decisiones y próximos pasos&quot;."
                                   Style="{StaticResource CaptionText}" Margin="2,0,0,6"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding Instruction, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolean}}"
                                 AutomationProperties.Name="Instrucción para unir las notas"/>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Button Content="Unir en un documento" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Command="{Binding MergeCommand}"
                                Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}"/>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                            <controls:Spinner Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Uniendo…" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="{DynamicResource Danger}"
                               TextWrapping="Wrap" FontSize="12" Margin="0,10,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}"/>

                    <TextBlock Grid.Row="4" Text="{Binding TruncatedWarning}" Foreground="{DynamicResource Warning}"
                               TextWrapping="Wrap" FontSize="12" Margin="0,10,0,0"
                               Visibility="{Binding TruncatedWarning, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}"/>

                    <!-- Resultado (streaming en vivo). -->
                    <Border Grid.Row="5" Background="{DynamicResource SurfaceAlt}" CornerRadius="10"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            Padding="10" Margin="0,10,0,0" MinHeight="180"
                            Visibility="{Binding ResultText, Converter={StaticResource CountToVisibility}, ConverterParameter=Invert}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding OperationStatusText}" FontSize="11"
                                           VerticalAlignment="Center" Foreground="{DynamicResource Success}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Copiar" Style="{StaticResource LinkButton}" FontSize="11"
                                            Margin="0,0,10,0" Command="{Binding CopyResultCommand}"/>
                                    <Button Content="Guardar como nota" Style="{StaticResource LinkButton}" FontSize="11"
                                            Command="{Binding SaveAsNoteCommand}"/>
                                </StackPanel>
                            </Grid>
                            <TextBox Text="{Binding ResultText, Mode=OneWay}" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"
                                     Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                     FontSize="13" Margin="0,8,0,0"
                                     VerticalScrollBarVisibility="Auto" MaxHeight="320"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
