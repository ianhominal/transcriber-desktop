<Window x:Class="AudioTranscriber.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioTranscriber.App.Controls"
        SizeToContent="Height" Width="420" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource Bg}" FontFamily="Segoe UI" FontSize="14"
        Foreground="{DynamicResource TextPrimary}" Title="Iniciar sesión — Audio Transcriber">

    <!-- Google es el método de login PRIMARIO (arriba, prominente, con el logo oficial de 4
         colores dibujado en XAML). Email/contraseña queda como alternativa secundaria debajo de
         un divisor "o con email". Misma paleta/estilos que MainWindow/SyncWindow (Card, Accent,
         PrimaryButton/SecondaryButton, InputBox) para que se sienta parte de la misma app. -->
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel Margin="32,28,32,28">

            <!-- ===== Encabezado: logo (mismo waveform indigo que el resto de la app) + título ===== -->
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource Accent}">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <!-- 5 barras redondeadas, igual al WaveIcon del login web (audio-transcriber-web) -->
                            <Rectangle Canvas.Left="2.5" Canvas.Top="8" Width="3" Height="8" RadiusX="1.5" RadiusY="1.5" Fill="White"/>
                            <Rectangle Canvas.Left="6.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1.5" RadiusY="1.5" Fill="White"/>
                            <Rectangle Canvas.Left="10.5" Canvas.Top="2" Width="3" Height="20" RadiusX="1.5" RadiusY="1.5" Fill="White"/>
                            <Rectangle Canvas.Left="14.5" Canvas.Top="5" Width="3" Height="14" RadiusX="1.5" RadiusY="1.5" Fill="White"/>
                            <Rectangle Canvas.Left="18.5" Canvas.Top="7" Width="3" Height="10" RadiusX="1.5" RadiusY="1.5" Fill="White"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Text="Audio Transcriber" Style="{StaticResource TitleText}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
            <TextBlock Text="Iniciá sesión para sincronizar tu carpeta" Style="{StaticResource SubtitleText}"
                       Margin="0,10,0,0"/>

            <!-- ===== Google, método principal ===== -->
            <Button x:Name="GoogleSignInButton" Style="{StaticResource SecondaryButton}"
                    Padding="16,13" Margin="0,22,0,0" Click="OnGoogleSignIn">
                <StackPanel x:Name="GoogleButtonContent" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <!-- "G" de Google, colores oficiales — misma forma que GoogleIcon (SVG) del login web -->
                            <Path Fill="#4285F4" Data="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1Z"/>
                            <Path Fill="#34A853" Data="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
                            <Path Fill="#FBBC05" Data="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"/>
                            <Path Fill="#EA4335" Data="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Continuar con Google" Margin="10,0,0,0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- ===== Divisor "o con email" ===== -->
            <Grid Margin="0,20,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="1" Background="{DynamicResource Border}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="o con email" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TextMuted}"/>
                <Border Grid.Column="2" Height="1" Background="{DynamicResource Border}" VerticalAlignment="Center"/>
            </Grid>

            <!-- ===== Email/contraseña, alternativa secundaria ===== -->
            <TextBlock Text="Email" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="2,0,0,4"/>
            <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}" Padding="8,7"/>

            <TextBlock Text="Contraseña" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="2,12,0,4"/>
            <PasswordBox x:Name="PasswordInput" Style="{StaticResource PasswordBoxInput}" Padding="8,7"/>

            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Danger}" FontSize="12"
                       TextWrapping="Wrap" Margin="2,10,0,0"/>

            <Button x:Name="SignInButton" Content="Entrar" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Margin="0,14,0,0" Click="OnSignIn"/>

            <!-- Indicador de "trabajando": SignInButton se deshabilita en AMBOS flujos (email y
                 Google, ver LoginWindow.xaml.cs), así que este único spinner cubre los dos casos
                 sin duplicar lógica. Vive fuera del botón (bindeado por ElementName) porque el
                 code-behind reemplaza el Content del botón por texto plano mientras dura la
                 operación, y no queremos tocar esa lógica. -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0"
                        Visibility="{Binding IsEnabled, ElementName=SignInButton, Converter={StaticResource InverseBoolToVisibility}}">
                <controls:Spinner Width="14" Height="14"/>
                <TextBlock Text="Verificando credenciales…" Style="{StaticResource CaptionText}" Margin="8,0,0,0"/>
            </StackPanel>

            <Button Content="Cancelar" Style="{StaticResource LinkButton}"
                    HorizontalAlignment="Center" Margin="0,10,0,0" IsCancel="True"/>

        </StackPanel>
    </Border>
</Window>
